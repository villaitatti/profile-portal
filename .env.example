# =============================================
# I Tatti Profile Portal — Environment Variables
# =============================================
# Copy this file to .env and fill in the values.

# Server
NODE_ENV=development
PORT=3000

# Scheduled automations (July 1 end-of-year cleanup + July 2 new-cohort onboarding).
# Leave unset/false on dev and staging. Set to 'true' ONLY on the real production
# instance — otherwise the dev server would fire those cron jobs against real
# Auth0/JSM/CiviCRM on July 1/2. Manual dry-run/execute from the admin UI is
# unaffected by this flag.
AUTOMATIONS_ENABLED=false

# CORS — required in production (server refuses to start without it)
# CORS_ORIGIN=https://dev-profile.itatti.net

# Auth0 - JWT verification
AUTH0_DOMAIN=harvard.eu.auth0.com
AUTH0_AUDIENCE=https://api.itatti.harvard.edu

# Auth0 - Management API (M2M application)
AUTH0_M2M_CLIENT_ID=
AUTH0_M2M_CLIENT_SECRET=
AUTH0_CONNECTION=Username-Password-Authentication
AUTH0_FELLOWS_ROLE_ID=
# Role granted only to the current academic year's cohort. Required for the
# annual end-of-year cleanup + new-cohort onboarding automations.
AUTH0_FELLOWS_CURRENT_ROLE_ID=

# CiviCRM
CIVICRM_BASE_URL=https://civicrm.itatti.harvard.edu
CIVICRM_API_KEY=
CIVICRM_SITE_KEY=

# CiviCRM field mapping (customize to match your CiviCRM instance)
CIVICRM_FELLOWSHIP_ENTITY=Custom_Fellowships
CIVICRM_FIELD_START_DATE=Fellowship_Start_Date
CIVICRM_FIELD_END_DATE=Fellowship_End_Date
CIVICRM_FIELD_ACCEPTED=Fellowship_Accepted
CIVICRM_FIELD_APPOINTMENT=Appointment
CIVICRM_FIELD_FELLOWSHIP=Fellowship

# Jira Service Management
JIRA_BASE_URL=https://itatti.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_SERVICE_DESK_ID=
JIRA_REQUEST_TYPE_ID=

# Atlassian SCIM provisioning (optional — sync disabled if not configured)
# Set up at admin.atlassian.com → Security → Identity Providers → SCIM directory
ATLASSIAN_SCIM_BASE_URL=https://api.atlassian.com/scim/directory
ATLASSIAN_SCIM_DIRECTORY_ID=
ATLASSIAN_SCIM_BEARER_TOKEN=

# Atlassian JSM Organizations — used to add/remove appointees from the
# "Former Appointees" and "Current Appointees" JSM orgs on both I Tatti
# sites. All eight values must be set for org management to activate;
# if any are missing, the feature is silently disabled.
# SITE1/SITE2 URLs look like https://itatti.atlassian.net
# Org IDs are the ARIs from admin.atlassian.com → Directory → Organizations
ATLASSIAN_JSM_SITE1_URL=
ATLASSIAN_JSM_SITE1_FORMER_ORG_ID=
ATLASSIAN_JSM_SITE1_CURRENT_ORG_ID=
ATLASSIAN_JSM_SITE2_URL=
ATLASSIAN_JSM_SITE2_FORMER_ORG_ID=
ATLASSIAN_JSM_SITE2_CURRENT_ORG_ID=

# AWS SES — transactional email (claim notifications + automation reports).
# Optional; if AWS_SES_REGION / AWS_SES_FROM_EMAIL / ADMIN_NOTIFICATION_EMAIL
# are missing the app logs emails instead of sending them.
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=
ADMIN_NOTIFICATION_EMAIL=

# AWS credentials — read automatically by the AWS SDK from process.env.
# Leave blank if the host uses an IAM role (EC2, ECS, Lambda) instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SSE token secret (optional — random key generated if not set)
# Recommended in production so SSE tokens survive container restarts.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SSE_SECRET=

# Database (PostgreSQL)
DATABASE_URL=postgresql://portal:portal@localhost:5432/profile_portal

# Frontend (VITE_ prefix — exposed to the browser)
VITE_AUTH0_DOMAIN=harvard.eu.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://api.itatti.harvard.edu
VITE_AUTH0_CALLBACK_URL=http://localhost:5173/callback
VITE_AUTH0_NAMESPACE=https://auth0.itatti.harvard.edu
VITE_API_BASE_URL=http://localhost:3000
VITE_CIVICRM_URL=https://dev-crm.itatti.net
