{
  "name": "@itatti/server",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm build:email-templates && tsup src/index.ts --format esm --config tsup.config.ts",
    "build:email-templates": "tsx scripts/build-email-templates.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1030.0",
    "@itatti/shared": "workspace:*",
    "@prisma/client": "^6.19.0",
    "auth0": "^4.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "express-jwt": "^8.5.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jwks-rsa": "^3.2.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^6.0.2",
    "@types/mjml": "^5.0.0",
    "@types/node": "^25.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "mjml": "^5.0.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.19.0",
    "supertest": "^7.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
