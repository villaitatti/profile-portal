generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Application {
  id            Int      @id @default(autoincrement())
  name          String
  description   String?
  url           String
  imageUrl      String?  @map("image_url")
  loginMethod   String   @default("vit-id") @map("login_method")
  requiredRoles String[] @map("required_roles")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("applications")
}

model SyncRun {
  id          String    @id @default(uuid())
  status      String    // dry_run | executing | completed | failed | partial
  triggeredBy String    @map("triggered_by")
  dryRunId    String?   @map("dry_run_id")
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  diff        Json      // full diff payload
  result      Json?     // per-operation execution log
  stats       Json?     // summary stats

  dryRun     SyncRun?  @relation("DryRunExecution", fields: [dryRunId], references: [id])
  executions SyncRun[] @relation("DryRunExecution")

  @@index([status, startedAt(sort: Desc)])
  @@map("sync_runs")
}

model VitIdClaim {
  id                   String   @id @default(uuid())
  email                String
  firstName            String   @map("first_name")
  lastName             String   @map("last_name")
  civicrmId            Int      @map("civicrm_id")
  hasFellowship        Boolean  @map("has_fellowship")
  hasCurrentFellowship Boolean  @map("has_current_fellowship")
  rolesAssigned        String[] @map("roles_assigned")
  orgsAssigned         String[] @map("orgs_assigned")
  claimedAt            DateTime @default(now()) @map("claimed_at")

  @@index([email])
  @@index([claimedAt(sort: Desc)])
  @@map("vit_id_claims")
}

model AutomationRun {
  id           String    @id @default(uuid())
  type         String    // end-of-year-cleanup | new-cohort-onboarding | backfill
  status       String    // dry_run | executing | completed | failed | partial
  triggeredBy  String    @map("triggered_by") // cron | admin:{email}
  academicYear String    @map("academic_year")
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  result       Json      // { processed, pending, errors, details: [...] }
  stats        Json?     // { removed, added, pending, errors }

  @@index([type, startedAt(sort: Desc)])
  @@map("automation_runs")
}

model RoleGroupMapping {
  id                 String   @id @default(uuid())
  auth0RoleId        String   @map("auth0_role_id")
  auth0RoleName      String   @map("auth0_role_name")
  atlassianGroupId   String?  @map("atlassian_group_id")
  atlassianGroupName String   @map("atlassian_group_name")
  createdBy          String?  @map("created_by")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@unique([auth0RoleId, atlassianGroupId])
  @@index([auth0RoleId])
  @@map("role_group_mappings")
}

enum AppointeeEmailType {
  BIO_PROJECT_DESCRIPTION
  VIT_ID_INVITATION

  @@map("appointee_email_type")
}

enum AppointeeEmailStatus {
  PENDING
  SENDING
  SENT
  FAILED
  SKIPPED

  @@map("appointee_email_status")
}

// Tracks each delivery attempt for per-fellowship, per-type transactional
// emails to appointees (bio & project description request, VIT ID invitation).
// Multiple rows may exist for the same (fellowshipId, emailType) so resend
// history is preserved for the future email log page.
//
// Dashboard state reads the latest row per (fellowshipId, emailType). A raw
// partial unique index in migration 20260424170000 prevents duplicate
// in-flight rows (PENDING/SENDING) while allowing historical SENT/FAILED/
// SKIPPED rows to accumulate.
model AppointeeEmailEvent {
  id            String               @id @default(cuid())
  fellowshipId  Int                  @map("fellowship_id")
  contactId     Int                  @map("contact_id")
  academicYear  String               @map("academic_year")
  emailType     AppointeeEmailType   @map("email_type")
  status        AppointeeEmailStatus @default(PENDING)
  enqueuedAt    DateTime             @default(now()) @map("enqueued_at")
  sendAfter     DateTime             @map("send_after")
  sentAt        DateTime?            @map("sent_at")
  failureReason String?              @map("failure_reason")
  triggeredBy   String               @map("triggered_by") // "claim_auto" | "admin_manual:<userId>"
  sesMessageId  String?              @map("ses_message_id")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([fellowshipId, emailType, createdAt(sort: Desc)])
  @@index([status, sendAfter])
  @@index([contactId, academicYear]) // audit scans
  @@map("appointee_email_events")
}
